{
  "expo": {
    "name": "Loyalty Card Wallet",
    "slug": "loyalty-card-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "loyaltycardwallet",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "18.0",
      "bundleIdentifier": "com.anonymous.loyalty-card-wallet",
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "package": "com.anonymous.loyaltycardwallet",
      "userInterfaceStyle": "dark"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0B",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220,
          "dark": {
            "backgroundColor": "#0A0A0B",
            "image": "./assets/splash-icon.png"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Loyalty Card Wallet to scan loyalty card barcodes and add card images.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Loyalty Card Wallet to scan loyalty card barcodes and add card images.",
          "microphonePermission": false,
          "photosPermission": "Allow Loyalty Card Wallet to select barcode images for adding cards."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Loyalty Card Wallet to use your location to find nearby stores."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Loyalty Card Wallet to use Face ID to unlock your local wallet."
        }
      ],
      "expo-sharing",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 30
          },
          "ios": {
            "deploymentTarget": "18.0"
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-maps",
        {
          "requestLocationPermission": false
        }
      ],
      "./plugins/external-surfaces"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
