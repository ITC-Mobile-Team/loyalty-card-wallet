<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/loyalty_card_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/loyalty_card_widget_background"
  android:gravity="center_vertical"
  android:orientation="vertical"
  android:padding="16dp">

  <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/loyalty_card_widget_label"
    android:textColor="@color/loyalty_card_widget_secondary"
    android:textSize="10sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/loyalty_card_widget_title"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:ellipsize="end"
    android:maxLines="2"
    android:textColor="@color/loyalty_card_widget_primary"
    android:textSize="18sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/loyalty_card_widget_number"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:ellipsize="end"
    android:maxLines="1"
    android:textColor="@color/loyalty_card_widget_secondary"
    android:textSize="12sp" />

  <TextView
    android:id="@+id/loyalty_card_widget_action"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:textColor="@color/loyalty_card_widget_primary"
    android:textSize="11sp"
    android:textStyle="bold" />
</LinearLayout>
