{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmit": false,
    "outDir": ".test-build",
    "rootDir": "."
  },
  "include": [
    "src/core/**/*.ts",
    "src/data/**/*.ts",
    "src/domain/**/*.ts",
    "src/features/stores/**/*.ts",
    "src/features/sharing/**/*.ts",
    "src/features/importing/**/*.ts",
    "test/**/*.ts"
  ]
}
